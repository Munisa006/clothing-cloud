# Copy to .env and adjust. docker-compose reads these automatically.

# Database
DB_USER=portal
DB_PASSWORD=portal_password
DB_NAME=portal

# Admin console credentials.
ADMIN_USER=admin

# Password — choose ONE of the following:
#
#  (a) Production: store a hashed password and remove ADMIN_PASSWORD.
#      Generate the hash with:  cd backend && npm run hash-password -- 'your-password'
#  ADMIN_PASSWORD_HASH=scrypt$...$...
#
#  (b) Local/demo: a plaintext password, hashed in memory at startup.
ADMIN_PASSWORD=admin123

# Secret used to sign admin session tokens (change to a long random string)
SESSION_SECRET=dev-secret-change-me
